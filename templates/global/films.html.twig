{% extends 'base.html.twig' %}

{% block title %}Films - Movie Explorer
{% endblock %}

{% block body %}
	<style>
		.example-wrapper {
			margin: 1em auto;
			max-width: 800px;
			width: 95%;
			font: 18px / 1.5 sans-serif;
		}
		.example-wrapper code {
			background: #F5F5F5;
			padding: 2px 6px;
		}
	</style>

	<div class="example-wrapper">
		<h1>{{ titre }}</h1>
		<ul>
			{% for film in films %}
				<li>{{film.title}}
					-
					{{film.année}}</li>
			{% else %}
				<li>Aucun films disponible</li>
			{% endfor %}
		</ul>
	</div>
{% endblock %}
